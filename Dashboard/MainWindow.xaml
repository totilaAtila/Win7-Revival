<Window
    x:Class="CrystalFrame.Dashboard.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="CrystalFrame Settings">

    <!-- Fără RequestedTheme forțat — urmează tema sistemului.
         NOTĂ: Window.Resources cu Style+ControlTemplate crashează XamlCompiler net472 Pass1.
         Proprietățile butoanelor sunt aplicate direct pe fiecare control (workaround). -->
    <Grid x:Name="RootGrid"
          HorizontalAlignment="Left"
          VerticalAlignment="Top"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <!-- Singura coloană — nu mai există side panel -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="16,8,16,12">
            <TextBlock Text="CRYSTAL"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#0078D4"/>
            <TextBlock Text="FRAME"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,-4,0,0"/>
        </StackPanel>

        <!-- Butoane navigare + controale stare -->
        <StackPanel Grid.Row="1" Spacing="6" Margin="12,0,12,0">

            <!-- Nav: Taskbar -->
            <Button x:Name="NavTaskbar"
                    Height="44"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Center"
                    Padding="12,0"
                    BorderThickness="0"
                    CornerRadius="6"
                    Click="Nav_Taskbar_Click">
                <TextBlock Text="Taskbar" FontSize="13"/>
            </Button>

            <!-- Nav: Start Menu -->
            <Button x:Name="NavStartMenu"
                    Height="44"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Center"
                    Padding="12,0"
                    BorderThickness="0"
                    CornerRadius="6"
                    Click="Nav_Start_Click">
                <TextBlock Text="Start Menu" FontSize="13"/>
            </Button>

            <!-- Separator -->
            <Border Height="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                    Margin="0,4"/>

            <!-- Core Engine -->
            <Border Height="44"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="6"
                    Padding="12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0"
                             x:Name="CoreStatusDot"
                             Width="8" Height="8" Fill="Gray"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="Core Engine"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="CoreStatusDetail"
                                   FontSize="9"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="2"
                                  x:Name="CoreRunningToggle"
                                  OnContent="ON" OffContent="OFF"
                                  MinWidth="0"
                                  Toggled="CoreRunning_Toggled"
                                  VerticalAlignment="Center"
                                  Margin="4,-4,0,0"/>
                </Grid>
            </Border>

            <!-- Run at startup -->
            <Border Height="44"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="6"
                    Padding="12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Run at startup"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <ToggleSwitch Grid.Column="1"
                                  x:Name="RunAtStartupToggle"
                                  OnContent="ON" OffContent="OFF"
                                  MinWidth="0"
                                  Toggled="RunAtStartup_Toggled"
                                  VerticalAlignment="Center"
                                  Margin="4,-4,0,0"/>
                </Grid>
            </Border>

        </StackPanel>

        <!-- Footer: status conexiune -->
        <Border Grid.Row="2"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Margin="0,8,0,0"
                Padding="16,10,16,12">
            <StackPanel Spacing="3">
                <TextBlock x:Name="ConnectionStatusText"
                           MaxWidth="280"
                           FontSize="10"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="DebugStatusText"
                           FontSize="9" Foreground="Orange"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
