<Window
    x:Class="CrystalFrame.Dashboard.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="CrystalFrame Settings">

    <Grid x:Name="RootGrid"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <RowDefinition Height="*"/>     <RowDefinition Height="Auto"/>  </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="16,12,16,12">
            <TextBlock Text="CRYSTAL"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#0078D4"/>
            <TextBlock Text="FRAME"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,-4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,0,16,0">

            <StackPanel MaxWidth="500"
                        HorizontalAlignment="Center"
                        Spacing="10"
                        Margin="0,0,0,12">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            x:Name="NavTaskbar"
                            MinHeight="50"
                            Margin="0,0,4,0"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            HorizontalAlignment="Stretch"
                            Click="Nav_Taskbar_Click">
                        <TextBlock Text="Taskbar" FontSize="14" FontWeight="Medium"/>
                    </Button>
                    <Button Grid.Column="1"
                            x:Name="NavStartMenu"
                            MinHeight="50"
                            Margin="4,0,0,0"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            HorizontalAlignment="Stretch"
                            Click="Nav_Start_Click">
                        <TextBlock Text="Start Menu" FontSize="14" FontWeight="Medium"/>
                    </Button>
                </Grid>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="16,12"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Ellipse Grid.Column="0"
                                 x:Name="CoreStatusDot"
                                 Width="10" Height="10" Fill="Gray"
                                 VerticalAlignment="Center"
                                 Margin="0,0,12,0"/>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Core Engine Status"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock x:Name="CoreStatusDetail"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        
                        <ToggleSwitch Grid.Column="2"
                                      x:Name="CoreRunningToggle"
                                      OnContent="ON" OffContent="OFF"
                                      MinWidth="0"
                                      Toggled="CoreRunning_Toggled"
                                      VerticalAlignment="Center"
                                      Margin="12,0,0,0"/>
                    </Grid>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="16,12"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Run application at system startup"
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,12,0"/>
                        <ToggleSwitch Grid.Column="1"
                                      x:Name="RunAtStartupToggle"
                                      OnContent="ON" OffContent="OFF"
                                      MinWidth="0"
                                      Toggled="RunAtStartup_Toggled"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,12">
            <StackPanel Spacing="4">
                <TextBlock x:Name="ConnectionStatusText"
                           FontSize="11"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="DebugStatusText"
                           FontSize="10" Foreground="Orange"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>