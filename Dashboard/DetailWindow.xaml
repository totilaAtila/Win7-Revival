<Window
    x:Class="GlassBar.Dashboard.DetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        
        <Border x:Name="RootBorder"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                Padding="16,12,16,24">

            <Grid MaxWidth="500" HorizontalAlignment="Center">

                <StackPanel x:Name="TaskbarPanel" Spacing="16" Visibility="Visible">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Taskbar Overlay"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                        <ToggleSwitch Grid.Column="1"
                                      x:Name="TaskbarEnabledToggle"
                                      OnContent="" OffContent=""
                                      Toggled="TaskbarEnabled_Toggled"
                                      Margin="12,0,0,0"
                                      MinWidth="0"/>
                    </Grid>

                    <TextBlock x:Name="TaskbarStatusText"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Transparency"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="%"
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Slider Grid.Column="1" x:Name="TaskbarOpacitySlider"
                                    Minimum="0" Maximum="100" StepFrequency="1"
                                    ValueChanged="TaskbarOpacity_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="TaskbarOpacityValue"
                                       TextAlignment="Right" VerticalAlignment="Center" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Background Color"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="R" VerticalAlignment="Center" FontSize="11" Foreground="#FF6060"/>
                            <Slider Grid.Column="1" x:Name="TaskbarColorRSlider"
                                    Minimum="0" Maximum="255" StepFrequency="1"
                                    ValueChanged="TaskbarColorR_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="TaskbarColorRValue"
                                       TextAlignment="Right" VerticalAlignment="Center" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="G" VerticalAlignment="Center" FontSize="11" Foreground="#60C060"/>
                            <Slider Grid.Column="1" x:Name="TaskbarColorGSlider"
                                    Minimum="0" Maximum="255" StepFrequency="1"
                                    ValueChanged="TaskbarColorG_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="TaskbarColorGValue"
                                       TextAlignment="Right" VerticalAlignment="Center" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="B" VerticalAlignment="Center" FontSize="11" Foreground="#6080FF"/>
                            <Slider Grid.Column="1" x:Name="TaskbarColorBSlider"
                                    Minimum="0" Maximum="255" StepFrequency="1"
                                    ValueChanged="TaskbarColorB_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="TaskbarColorBValue"
                                       TextAlignment="Right" VerticalAlignment="Center" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>

                        <Border Height="20" CornerRadius="4" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                            <Border x:Name="TaskbarColorPreview" Background="Black" CornerRadius="3"/>
                        </Border>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Blur effect (acrylic)"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                        <ToggleSwitch Grid.Column="1"
                                      x:Name="TaskbarBlurToggle"
                                      OnContent="" OffContent=""
                                      Toggled="TaskbarBlur_Toggled"
                                      Margin="12,0,0,0"
                                      MinWidth="0"/>
                    </Grid>
                </StackPanel>

                <StackPanel x:Name="StartMenuPanel" Spacing="16" Visibility="Collapsed">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Start Menu Overlay"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                        <ToggleSwitch Grid.Column="1"
                                      x:Name="StartEnabledToggle"
                                      OnContent="" OffContent=""
                                      Toggled="StartEnabled_Toggled"
                                      Margin="12,0,0,0"
                                      MinWidth="0"/>
                    </Grid>

                    <TextBlock x:Name="StartStatusText"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Transparency" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="%" VerticalAlignment="Center" FontSize="11" Opacity="0.6"/>
                            <Slider Grid.Column="1" x:Name="StartOpacitySlider" Minimum="0" Maximum="100" StepFrequency="1" ValueChanged="StartOpacity_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="StartOpacityValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                        </Grid>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Blur effect (acrylic)" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        <ToggleSwitch Grid.Column="1" x:Name="StartBlurToggle" OnContent="" OffContent="" Toggled="StartBlur_Toggled" Margin="12,0,0,0" MinWidth="0"/>
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Background Color" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <TextBlock Text="R" VerticalAlignment="Center" FontSize="11" Foreground="#FF6060"/>
                            <Slider Grid.Column="1" x:Name="StartBgColorRSlider" Minimum="0" Maximum="255" ValueChanged="StartBgColorR_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="StartBgColorRValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <TextBlock Text="G" VerticalAlignment="Center" FontSize="11" Foreground="#60C060"/>
                            <Slider Grid.Column="1" x:Name="StartBgColorGSlider" Minimum="0" Maximum="255" ValueChanged="StartBgColorG_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="StartBgColorGValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <TextBlock Text="B" VerticalAlignment="Center" FontSize="11" Foreground="#6080FF"/>
                            <Slider Grid.Column="1" x:Name="StartBgColorBSlider" Minimum="0" Maximum="255" ValueChanged="StartBgColorB_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="StartBgColorBValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                        </Grid>
                        <Border Height="20" CornerRadius="4" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                            <Border x:Name="StartBgColorPreview" Background="Black" CornerRadius="3"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Text Color" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <TextBlock Text="R" VerticalAlignment="Center" FontSize="11" Foreground="#FF6060"/>
                            <Slider Grid.Column="1" x:Name="StartTextColorRSlider" Minimum="0" Maximum="255" ValueChanged="StartTextColorR_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="StartTextColorRValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <TextBlock Text="G" VerticalAlignment="Center" FontSize="11" Foreground="#60C060"/>
                            <Slider Grid.Column="1" x:Name="StartTextColorGSlider" Minimum="0" Maximum="255" ValueChanged="StartTextColorG_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="StartTextColorGValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <TextBlock Text="B" VerticalAlignment="Center" FontSize="11" Foreground="#6080FF"/>
                            <Slider Grid.Column="1" x:Name="StartTextColorBSlider" Minimum="0" Maximum="255" ValueChanged="StartTextColorB_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="StartTextColorBValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                        </Grid>
                        <Border Height="20" CornerRadius="4" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                            <Border x:Name="StartTextColorPreview" Background="White" CornerRadius="3"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Menu Items" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        <Grid ColumnSpacing="8" RowSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <CheckBox Grid.Row="0" Grid.Column="0" x:Name="StartShowControlPanel" Content="Control Panel" FontSize="12" Checked="StartMenuItem_Changed" Unchecked="StartMenuItem_Changed"/>
                            <CheckBox Grid.Row="0" Grid.Column="1" x:Name="StartShowDeviceManager" Content="Device Mgr" FontSize="12" Checked="StartMenuItem_Changed" Unchecked="StartMenuItem_Changed"/>
                            <CheckBox Grid.Row="1" Grid.Column="0" x:Name="StartShowInstalledApps" Content="Installed Apps" FontSize="12" Checked="StartMenuItem_Changed" Unchecked="StartMenuItem_Changed"/>
                            <CheckBox Grid.Row="1" Grid.Column="1" x:Name="StartShowDocuments" Content="Documents" FontSize="12" Checked="StartMenuItem_Changed" Unchecked="StartMenuItem_Changed"/>
                            <CheckBox Grid.Row="2" Grid.Column="0" x:Name="StartShowPictures" Content="Pictures" FontSize="12" Checked="StartMenuItem_Changed" Unchecked="StartMenuItem_Changed"/>
                            <CheckBox Grid.Row="2" Grid.Column="1" x:Name="StartShowVideos" Content="Videos" FontSize="12" Checked="StartMenuItem_Changed" Unchecked="StartMenuItem_Changed"/>
                            <CheckBox Grid.Row="3" Grid.Column="0" x:Name="StartShowRecentFiles" Content="Recent Files" FontSize="12" Checked="StartMenuItem_Changed" Unchecked="StartMenuItem_Changed"/>
                        </Grid>
                    </StackPanel>

                    <!-- S-B: Keep Start Menu Open for preview -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Preview" FontSize="11" Foreground="#888" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Keep Start Menu Open" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Pin menu visible to preview effects in real time" FontSize="11" Foreground="#888" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" x:Name="StartMenuPinnedToggle" OnContent="" OffContent="" Toggled="StartMenuPinned_Toggled" Margin="12,0,0,0" MinWidth="0"/>
                        </Grid>
                    </StackPanel>

                    <!-- S-E: Border / Accent Color -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Border / Accent Color" FontSize="11" Foreground="#888" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="24,*,36" RowSpacing="4" ColumnSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="R" FontSize="11" VerticalAlignment="Center" Foreground="#E55"/>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="StartBorderColorRSlider" Minimum="0" Maximum="255" ValueChanged="StartBorderColorR_ValueChanged"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" x:Name="StartBorderColorRValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="G" FontSize="11" VerticalAlignment="Center" Foreground="#5A5"/>
                            <Slider Grid.Row="1" Grid.Column="1" x:Name="StartBorderColorGSlider" Minimum="0" Maximum="255" ValueChanged="StartBorderColorG_ValueChanged"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="StartBorderColorGValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="B" FontSize="11" VerticalAlignment="Center" Foreground="#55E"/>
                            <Slider Grid.Row="2" Grid.Column="1" x:Name="StartBorderColorBSlider" Minimum="0" Maximum="255" ValueChanged="StartBorderColorB_ValueChanged"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="StartBorderColorBValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                            <Border Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" x:Name="StartBorderColorPreview" Height="14" CornerRadius="3"/>
                        </Grid>
                    </StackPanel>

                    <!-- S-F: Theme Presets -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Theme Presets" FontSize="11" Foreground="#888" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="PresetClassicWin7Button" Content="Classic Win7" Click="PresetClassicWin7_Click" FontSize="12" Padding="10,6"/>
                            <Button x:Name="PresetAeroGlassButton" Content="Aero Glass" Click="PresetAeroGlass_Click" FontSize="12" Padding="10,6"/>
                            <Button x:Name="PresetDarkButton" Content="Dark" Click="PresetDark_Click" FontSize="12" Padding="10,6"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </Grid>
        </Border>
    </ScrollViewer>
</Window>