{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🏗️ Build (Full)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/build.ps1"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": false,
                "echo": true,
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "📦 Publish - Framework Dependent",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/.vscode/publish-prompt.ps1",
                "-ScriptPath",
                "${workspaceFolder}/publish.ps1"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true,
                "echo": true,
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "📦 Publish - Standalone",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/.vscode/publish-prompt.ps1",
                "-ScriptPath",
                "${workspaceFolder}/publish-standalone.ps1"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true,
                "echo": true,
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "🚀 Create GitHub Release",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/.vscode/publish-prompt.ps1",
                "-ScriptPath",
                "${workspaceFolder}/create-release.ps1",
                "-IsRelease"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true,
                "echo": true,
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "🧹 Clean All",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "Remove-Item .\\Core\\build -Recurse -Force -ErrorAction SilentlyContinue; Remove-Item .\\Dashboard\\bin -Recurse -Force -ErrorAction SilentlyContinue; Remove-Item .\\Dashboard\\obj -Recurse -Force -ErrorAction SilentlyContinue; Remove-Item .\\publish -Recurse -Force -ErrorAction SilentlyContinue; Write-Host 'Clean complete!' -ForegroundColor Green"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": false,
                "echo": true,
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "▶️ Run Dashboard",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "& '.\\Dashboard\\bin\\x64\\Release\\net8.0-windows10.0.22621.0\\CrystalFrame.Dashboard.exe'"
            ],
            "dependsOn": ["🏗️ Build (Full)"],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": false,
                "echo": true,
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "🎯 Quick Publish (1.0.0)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/create-release.ps1",
                "-Version",
                "1.0.0"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true,
                "echo": true,
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
